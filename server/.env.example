SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Use secure = true only if your provider uses port 465 (SSL). For Gmail on 587, keep false.
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
# Gmail: MUST be an "App password" (16 chars, no spaces), not your normal login password.
# Create it: Google Account → Security → 2-Step Verification → App passwords.
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# Optional "From" — plain email or: Display Name <email@domain.com>
OTP_FROM=your_email@gmail.com

# Shown in enrollment emails as support contact
SUPPORT_EMAIL=your_email@gmail.com

# Backend base URL used to build reset links (optional)
CLIENT_BASE_URL=http://localhost:3002

# Comma-separated list of allowed frontend origins (must include your Vite URL)
CLIENT_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:3002

# Auth (change in production)
JWT_SECRET=change-me-in-production

# Postgres connection string (example)
DATABASE_URL=postgresql://postgres:password@localhost:5432/course_academy?schema=public

