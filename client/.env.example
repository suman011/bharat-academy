# Optional: paste the FormSubmit form ID from the activation email (hex string).
# Keeps your Gmail out of the browser network tab; falls back to the email in code if unset.
# VITE_FORMSUBMIT_ID=your_hex_id_here

# --- API URL (required for many production setups) ---
# Dev: leave unset to use http://localhost:5002.
# Prod, same server as API: leave unset (uses same-origin URLs).
# Prod, static site on your domain + API on Render: set at BUILD time (Netlify/Vercel/CI env):
#   VITE_API_BASE=https://your-service-name.onrender.com
# No trailing slash.
# VITE_API_BASE=https://your-service-name.onrender.com

# Optional: footer Facebook link (defaults to Bharat Skill Academy Page if unset).
# VITE_SOCIAL_FACEBOOK=https://www.facebook.com/profile.php?id=61572054090601

# Optional: footer LinkedIn link (defaults to Bharat Skill Academy page if unset).
# VITE_SOCIAL_LINKEDIN=https://www.linkedin.com/company/bharat-skill-academy/
