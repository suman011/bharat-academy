# Optional: paste the FormSubmit form ID from the activation email (hex string).
# Keeps your Gmail out of the browser network tab; falls back to the email in code if unset.
# VITE_FORMSUBMIT_ID=your_hex_id_here

# Optional: full backend origin when the SPA is NOT served with Vite’s /api proxy
# (e.g. static dist on another host). No trailing slash. Example:
# VITE_API_BASE=http://localhost:5002
