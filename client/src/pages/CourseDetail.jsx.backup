            { title: 'Global Business Environment', concepts: 'Global Economics, Political Risk, Cultural Intelligence' },
            { title: 'International Strategy', concepts: 'Market Entry Modes, Internationalization Theories' },
            { title: 'Global Operations', concepts: 'International HRM, Global Supply Chains, Cross-cultural Management' }
          ]
        },
        {
          module: 'Innovation Management',
          submodules: [
            { title: 'Innovation Strategy', concepts: 'Innovation Portfolio, Open Innovation, Disruptive Innovation' },
            { title: 'Innovation Process', concepts: 'Idea Generation, Innovation Funnels, Stage-Gate Process' },
            { title: 'Innovation Culture', concepts: 'Innovation Metrics, Reward Systems, Failure Management' }
          ]
        },
        {
          module: 'Crisis Management',
          submodules: [
            { title: 'Crisis Planning', concepts: 'Risk Assessment, Crisis Scenarios, Contingency Planning' },
            { title: 'Crisis Response', concepts: 'Crisis Communication, Decision Making, Resource Allocation' },
            { title: 'Post-Crisis Management', concepts: 'Recovery Planning, Learning, Reputation Management' }
          ]
        },
        {
          module: 'Business Transformation',
          submodules: [
            { title: 'Transformation Strategy', concepts: 'Digital Transformation, Organizational Change, Culture Change' },
            { title: 'Change Implementation', concepts: 'Change Management Models, Resistance Management, Communication' },
            { title: 'Transformation Metrics', concepts: 'Success Measurement, ROI Analysis, Sustainability' }
          ]
        },
        {
          module: 'Executive Decision Making',
          submodules: [
            { title: 'Decision Frameworks', concepts: 'Rational Decision Making, Intuitive Decision Making, Group Decisions' },
            { title: 'Strategic Analysis', concepts: 'Scenario Planning, Decision Trees, Real Options' },
            { title: 'Risk Management', concepts: 'Risk Assessment, Risk Mitigation, Decision under Uncertainty' }
          ]
        }
      ]
    }
  };

  return curriculums[category]?.[level] || [
    {
      module: 'Course Introduction',
      submodules: [
        { title: 'Welcome & Overview', concepts: 'Course Goals, Structure, Resources' }
      ]
    },
    {
      module: 'Core Concepts',
      submodules: [
        { title: 'Fundamentals', concepts: 'Key Concepts, Industry Standards' }
      ]
    },
    {
      module: 'Practical Applications',
      submodules: [
        { title: 'Real-World Usage', concepts: 'Case Studies, Best Practices' }
      ]
    },
    {
      module: 'Advanced Topics',
      submodules: [
        { title: 'Advanced Concepts', concepts: 'Expert Techniques, Deep Dive' }
      ]
    },
    {
      module: 'Project Work',
      submodules: [
        { title: 'Hands-On Project', concepts: 'Implementation, Problem Solving' }
      ]
    },
    {
      module: 'Final Assessment',
      submodules: [
        { title: 'Evaluation & Certification', concepts: 'Testing, Certification' }
      ]
    }
  ];
};

export default function CourseDetail() {
  const { courseSlug } = useParams();
  const [activeTab, setActiveTab] = useState("overview");

  const allCourses = useMemo(
    () =>
      courseCategories.flatMap((category) =>
        category.items.map((course) => ({
          ...course,
          category: category.title,
          categoryColor: category.color,
          slug: slugify(course.name),
        }))
      ),
    []
  );

  console.log('Course slug from URL:', courseSlug);
  console.log('All courses:', allCourses.map(c => ({ name: c.name, slug: c.slug })));

  const course = allCourses.find((item) => item.slug === courseSlug);

  console.log('Found course:', course);

  if (!course) {
    return (
      <section className="section-page">
        <div className="container">
          <h2>Course not found</h2>
          <p>The course you are looking for does not exist.</p>
          <p>Debug info:</p>
          <p>Slug from URL: {courseSlug}</p>
          <p>Available courses: {allCourses.map(c => c.slug).join(', ')}</p>
          <Link className="primary-btn" to="/courses">
            Back to courses
          </Link>
        </div>
      </section>
    );
  }

  const descriptionLines = course.description ? course.description.split("\n\n") : [];
  const curriculumItems = getCurriculumForCourse(course.category, course.level);

  const renderTabContent = () => {
    switch (activeTab) {
      case "overview":
        return (
          <>
            <div className="tab-content-card">
              <h3>Course Overview</h3>
              <p>
                {course.description
                  ? descriptionLines[0] || "We have a detailed curriculum for this course."
                  : "No additional course overview is available yet."}
              </p>
              <div className="overview-grid">
                <div>
                  <strong>Duration</strong>
                  <p>{course.duration}</p>
                </div>
                <div>
                  <strong>Level</strong>
                  <p>{course.level}</p>
                </div>
                <div>
                  <strong>Price</strong>
                  <p>₹{course.price.toLocaleString("en-IN")}</p>
                </div>
                <div>
                  <strong>Category</strong>
                  <p>{course.category}</p>
                </div>
              </div>
            </div>
            <div className="course-summary">
              <h4>What You'll Learn</h4>
              <ul>
                {curriculumItems.slice(0, 6).map((item, index) => (
                  <li key={index}>{item}</li>
                ))}
              </ul>
              <div>
                <h4>Skills You'll Gain</h4>
                <p>
                  {course.category === 'Web Development' 
                    ? 'HTML, CSS, JavaScript, Responsive Design, Frontend Frameworks'
                    : course.category === 'Data Science' 
                    ? 'Python, Data Analysis, Machine Learning, Statistics, Data Visualization'
                    : course.category === 'Design' 
                    ? 'UI/UX Design, Prototyping, Design Tools, User Research'
                    : course.category === 'Marketing' 
                    ? 'Digital Marketing, SEO, Social Media, Content Strategy'
                    : course.category === 'Business' 
                    ? 'Business Strategy, Management, Entrepreneurship, Finance'
                    : 'Industry-relevant skills and practical knowledge'}
                </p>
              </div>
              {descriptionLines.length > 1 && (
                <div>
                  <h4>Course Highlights</h4>
                  <p>{descriptionLines.slice(1).join(' ').substring(0, 300)}{descriptionLines.slice(1).join(' ').length > 300 ? '...' : ''}</p>
                </div>
              )}
              <div>
                <h4>Prerequisites</h4>
                <p>
                  {course.level === 'Beginner' 
                    ? 'No prior experience required. This course is designed for complete beginners.' 
                    : course.level === 'Intermediate' 
                    ? `Basic knowledge of ${course.category} recommended.`
                    : `Strong foundation in ${course.category} required.`}
                </p>
              </div>
              <div>
                <h4>Who This Course Is For</h4>
                <p>
                  {course.level === 'Beginner' 
                    ? 'Perfect for students, career changers, and anyone interested in learning ' + course.category.toLowerCase() + '.'
                    : course.level === 'Intermediate' 
                    ? 'Ideal for professionals looking to advance their ' + course.category.toLowerCase() + ' skills.'
                    : 'Designed for experienced practitioners seeking advanced expertise in ' + course.category.toLowerCase() + '.'}
                </p>
              </div>
              <div>
                <h4>Career Opportunities</h4>
                <p>
                  {course.category === 'Web Development' 
                    ? 'Web Developer, Frontend Developer, Full-Stack Developer, UI Developer'
                    : course.category === 'Data Science' 
                    ? 'Data Analyst, Data Scientist, Machine Learning Engineer, BI Analyst'
                    : course.category === 'Design' 
                    ? 'UI/UX Designer, Product Designer, Graphic Designer, Design Lead'
                    : course.category === 'Marketing' 
                    ? 'Digital Marketing Specialist, SEO Specialist, Content Marketer, Marketing Manager'
                    : course.category === 'Business' 
                    ? 'Business Analyst, Project Manager, Entrepreneur, Business Consultant'
                    : 'Various career paths in ' + course.category}
                </p>
              </div>
              <div>
                <h4>Course Format</h4>
                <p>Self-paced online course with lifetime access. Learn at your own schedule with 24/7 support.</p>
              </div>
              <div>
                <h4>Course Materials</h4>
                <p>Video lectures, downloadable resources, practice exercises, quizzes, and project files included.</p>
              </div>
              <div>
                <h4>Assessment & Certification</h4>
                <p>Complete quizzes and projects to test your knowledge. Upon successful completion, receive a certificate of completion.</p>
              </div>
              <div>
                <h4>Support & Resources</h4>
                <p>Access to community forums, instructor Q&A sessions, and additional learning resources throughout your journey.</p>
              </div>
              <div>
                <h4>Course Details</h4>
                <p>This {course.level.toLowerCase()} course is perfect for learners in {course.category}. Complete your training in {course.duration} with expert guidance.</p>
              </div>
            </div>
          </>
        );
      case "curriculum":
        return (
          <div className="tab-content-card">
            <h3>Course Curriculum</h3>
            <p>This comprehensive curriculum is designed to take you from {course.level.toLowerCase()} to proficient in {course.category}. Each module builds upon the previous one, ensuring a logical learning progression.</p>
            {curriculumItems.length > 0 ? (
              <div className="curriculum-detailed">
                {curriculumItems.map((item, moduleIndex) => (
                  <div key={moduleIndex} className="curriculum-module">
                    <div className="module-header">
                      <h4>Module {moduleIndex + 1}: {item.module}</h4>
                    </div>
                    {item.submodules && item.submodules.length > 0 ? (
                      <ul className="submodules-list">
                        {item.submodules.map((submodule, subIndex) => (
                          <li key={subIndex} className="submodule-item">
                            <strong className="submodule-title">{submodule.title}</strong>
                            <p className="concepts-text">Topics: {submodule.concepts}</p>
                          </li>
                        ))}
                      </ul>
                    ) : (
                      <p>Module content details coming soon.</p>
                    )}
                  </div>
                ))}
              </div>
            ) : (
              <p>Curriculum details are being prepared. Please check back soon.</p>
            )}
          </div>
        );
      case "reviews":
        return (
          <div className="tab-content-card">
            <h3>Student Reviews</h3>
            <div className="review-card">
              <div className="review-header">
                <strong>Priya, 27</strong>
                <FaStar /> <FaStar /> <FaStar /> <FaStar /> <FaStar />
              </div>
              <p>Great practical material, strong teacher support, and real project examples helped me
                land a job in 3 months.</p>
            </div>
            <div className="review-card">
              <div className="review-header">
                <strong>Rohit, 34</strong>
                <FaStar /> <FaStar /> <FaStar /> <FaStar /> <FaStar />
              </div>
              <p>A good pacing course with solid coverage. I strongly recommend for beginners and
                intermediate learners.</p>
            </div>
          </div>
        );
      default:
        return null;
    }
  };

  return (
    <section className="section-page course-detail-page">
      <div className="container">
        <Link to="/courses" className="secondary-btn back-link">
          <FaArrowLeft /> Back to catalog
        </Link>

        <div className="course-detail-header">
          <h1>{course.name}</h1>
          <div className="course-meta-row">
            <div className="meta-item">
              <FaRupeeSign /> ₹{course.price.toLocaleString("en-IN")}
            </div>
            <div className="meta-item">
              <FaClock /> {course.duration}
            </div>
            <div className="meta-item">
              <FaGraduationCap /> {course.level}
            </div>
          </div>
        </div>

        <div className="tabs">
          <button
            className={activeTab === "overview" ? "tab active" : "tab"}
            onClick={() => setActiveTab("overview")}
          >
            Overview
          </button>
          <button
            className={activeTab === "curriculum" ? "tab active" : "tab"}
            onClick={() => setActiveTab("curriculum")}
          >
            Curriculum
          </button>
          <button
            className={activeTab === "reviews" ? "tab active" : "tab"}
            onClick={() => setActiveTab("reviews")}
          >
            Reviews
          </button>
        </div>

        <div className="tab-content">{renderTabContent()}</div>
      </div>
    </section>
  );
}
